# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local Claude Code tooling (personal skills/agents/settings — not project code)
.claude/

# vercel
.vercel

# raw photo originals — processed into public/gallery/ via `npm run gallery` (large, not served)
/gallery-source/

# graphify knowledge-graph output (generated)
/graphify-out/

# typescript
*.tsbuildinfo
next-env.d.ts
